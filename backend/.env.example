# ========================================
# Konfigurasi Environment Backend
# ========================================
# Salin file ini menjadi .env dan sesuaikan nilainya

# Database MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=upabk

# JWT Secret — WAJIB diganti dengan string acak yang kuat (min 32 karakter)
JWT_SECRET=GANTI_DENGAN_SECRET_YANG_KUAT_DAN_UNIK

# Port Server
PORT=5000

# Base URL server (untuk URL file upload) — sesuaikan dengan domain production
BASE_URL=http://localhost:5000

# CORS Origin (URL frontend, pisahkan dengan koma jika lebih dari satu)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Mode (development/production)
NODE_ENV=development
